# Ignore everything
*

# Allow directory traversal
!*/

# MyStudio plugin files
!inc/plugins/ms.php
!inc/plugins/mystudio/
!inc/plugins/mystudio/**
!admin/modules/mystudio/
!admin/modules/mystudio/**
!jscripts/mystudio/
!jscripts/mystudio/**

# MyStudio Default theme (ships with plugin)
!themes/
!themes/mystudio-default/
!themes/mystudio-default/**

# Exclude runtime artifacts inside themes
themes/**/.ms_last_sync

# Allow gitignore and README
!.gitignore
!README.md
