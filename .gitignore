# Ignore everything
*

# Allow directory traversal
!*/

# FMZ Studio plugin files
!inc/plugins/fmz.php
!inc/plugins/fmzstudio/
!inc/plugins/fmzstudio/**
!admin/modules/fmzstudio/
!admin/modules/fmzstudio/**
!jscripts/fmzstudio/
!jscripts/fmzstudio/**

# FMZ Default theme (ships with plugin)
!themes/
!themes/fmz-default/
!themes/fmz-default/**

# Exclude runtime artifacts inside themes
themes/**/.fmz_last_sync

# Allow gitignore and README
!.gitignore
!README.md
